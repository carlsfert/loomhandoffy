generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Video {
  id        String   @id @default(uuid())
  title     String
  author    String
  videoUrl  String
  views     Int      @default(0)
  ctaText   String?
  ctaLink   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
